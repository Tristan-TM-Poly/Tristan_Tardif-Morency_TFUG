{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Reusable Disruption Packet",
  "type": "object",
  "required": [
    "disruption_id",
    "name",
    "old_workflow",
    "new_workflow",
    "obsolete_assumption",
    "bridge_object",
    "advantage_metric",
    "minimum_demo",
    "required_gate",
    "required_evidence",
    "reuse_kernel",
    "feedback_plan",
    "blocked_claims",
    "rollback_path",
    "status",
    "next_least_action"
  ],
  "properties": {
    "disruption_id": {"type": "string"},
    "name": {"type": "string"},
    "old_workflow": {"type": "string"},
    "new_workflow": {"type": "string"},
    "obsolete_assumption": {"type": "string"},
    "bridge_object": {"type": "string"},
    "advantage_metric": {"type": "string"},
    "minimum_demo": {"type": "string"},
    "required_gate": {"type": "string"},
    "required_evidence": {"type": "array", "items": {"type": "string"}},
    "reuse_kernel": {"type": "string"},
    "feedback_plan": {"type": "string"},
    "transaction_or_impact_path": {"type": "string"},
    "blocked_claims": {"type": "array", "items": {"type": "string"}},
    "rollback_path": {"type": "string"},
    "status": {"type": "string"},
    "next_least_action": {"type": "string"},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
